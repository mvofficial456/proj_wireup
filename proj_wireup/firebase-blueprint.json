{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents the user's settings and basic info",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Global unique ID of the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "displayName": { "type": "string", "description": "Full name of the user" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Productivity Task",
      "description": "Represents a user challenge, project, assignment, or task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "deadline": { "type": "string", "format": "date" },
        "estimatedHours": { "type": "number" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in_progress", "completed", "missed"] },
        "riskScore": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "subtasks": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "deadline", "estimatedHours", "difficulty", "priority", "status"]
    },
    "Schedule": {
      "title": "AI Task Schedule Slot",
      "description": "Represents a structured study or action block created by the AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "day": { "type": "string" },
        "time": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "userId", "taskId", "day", "time", "durationMinutes"]
    },
    "Habit": {
      "title": "Productivity Habit Tracker",
      "description": "Represents positive micro-habits generated by the AI coach",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "streak": { "type": "number" },
        "completedToday": { "type": "boolean" },
        "lastCompleted": { "type": "string" }
      },
      "required": ["id", "userId", "title", "streak", "completedToday"]
    },
    "Analytics": {
      "title": "User Analytics Data",
      "description": "Tracks productivity scores and historical completion performance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productivityScore": { "type": "number" },
        "completedCount": { "type": "number" },
        "missedCount": { "type": "number" },
        "streakDays": { "type": "number" },
        "weeklyProgress": { "type": "array" }
      },
      "required": ["userId", "productivityScore", "completedCount", "missedCount", "streakDays"]
    },
    "Notification": {
      "title": "Context Aware Notification",
      "description": "Represents an active, personalized AI-crafted reminder",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "content", "timestamp", "read"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile metadata"
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Individual tasks with deadlines and risks"
    },
    "users/{userId}/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Structured AI schedules"
    },
    "users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "AI accountability habits"
    },
    "users/{userId}/analytics/{analyticsId}": {
      "schema": "Analytics",
      "description": "Historical productivity statistics"
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Contextual notifications"
    }
  }
}
